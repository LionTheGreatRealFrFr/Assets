                        local bottom_spacing = (Script.Visuals.ESP['Healthbar'] and Script.Visuals.ESP['Position'] == 'Bottom') and (8 + bar_thickness) or 5
                        local text_base_y = box_y + box_h + (is_full_box and 3 or 0) + bottom_spacing

