do
    function ESP_Stuff.functions:create(class, prop)
        local inst = TypeOf(class) == 'string' and NewInstance(class) or class

        for property, val in pairs(prop)do
            inst[property] = val
        end

        return inst
    end
    function ESP_Stuff.functions:is_visible(Destination)
        local part = Destination and Destination.PrimaryPart

        if not part then
            return false
        end

        local raycast_params = RaycastParams.new()
        local RaycastResult = Workspace:Raycast(Camera.CFrame.p, (part.Position - Camera.CFrame.p).Unit * 10000, raycast_params)

        return RaycastResult and RaycastResult.Instance:IsDescendantOf(Destination)
    end

    local increase = NewVector3(0, 0, 0)

    if game_name == 'Universal' then
        increase = NewVector3(0, 0, 0)
    else
        increase = NewVector3(0, 0, 0)
    end

    local vertices = {
        {
            -0.5,
            -0.5,
            -0.5,
        },
        {
            -0.5,
            0.5,
            -0.5,
        },
        {
            0.5,
            -0.5,
            -0.5,
        },
        {
            0.5,
            0.5,
            -0.5,
        },
        {
            -0.5,
            -0.5,
            0.5,
        },
        {
            -0.5,
            0.5,
            0.5,
        },
        {
            0.5,
            -0.5,
            0.5,
        },
        {0.5, 0.5, 0.5},
    }

    function ESP_Stuff.functions:custom_bounds(model)
        local min_bound, max_bound = NewVector3(MathHuge, MathHuge, MathHuge), NewVector3(-MathHuge, -MathHuge, -MathHuge)
        local min_width = 2.5

        for _, part in model:GetChildren()do
            if part:IsA('BasePart') then
                local cframe, size = part.CFrame, part.Size

                for _, v in vertices do
                    local world_space = cframe:PointToWorldSpace(NewVector3(v[1] * size.X, (v[2] + 0.2) * (size.Y + 0.2), v[3] * size.Z))

                    min_bound = NewVector3(MathMin(min_bound.X, world_space.X), MathMin(min_bound.Y, world_space.Y), MathMin(min_bound.Z, world_space.Z))
                    max_bound = NewVector3(MathMax(max_bound.X, world_space.X), MathMax(max_bound.Y, world_space.Y), MathMax(max_bound.Z, world_space.Z))
                end
            end
        end

        if min_bound == NewVector3(MathHuge, MathHuge, MathHuge) then
            return
        end

        local size = max_bound - min_bound

        size = NewVector3(MathMax(size.X, min_width), size.Y, size.Z)

        local center = (min_bound + max_bound) / 2

        return NewCFrame(center), size + increase, center
    end
end

ESP_Stuff.functions.get_tool_name = LPH_NO_VIRTUALIZE(function(self, character)
    for _, v in character:GetChildren()do
        if not v:IsA('Model') then
            continue
        end
        if v.Name == 'Hair' or v.Name == 'HolsterModel' then
            continue
        end
        if not v.PrimaryPart then
            continue
        end
        if v:FindFirstChild('Detail') or v:FindFirstChild('Main') or v:FindFirstChild('Handle') or v:FindFirstChild('Attachments') or v:FindFirstChild('ArrowAttach') or v:FindFirstChild('Attach') then
            return v.Name
        end
    end

    return 'none'
end)

