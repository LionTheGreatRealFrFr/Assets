                        end
                        if (on_screen) and Script.Visuals.ESP['Healthbar'] then
                            local health, max_health = MathFloor(humanoid.Health), humanoid.MaxHealth
                            local health_color = NewColor3(1, 0, 0):lerp(NewColor3(0.7, 0.8, 0), MathClamp(health / max_health, 0, 1))

                            health_color = health_color:lerp(NewColor3(0, 1, 0), MathClamp((health / max_health - 0.5) * 2, 0, 1))

                            local health_offset = MathFloor((max_health - health) / 10) * 0.1

                            do
                                health_start = health_start or 0
                                health_transition_start = health_transition_start or health
                                health_transition_old = health_transition_old or health
                                current_health = current_health or health

                                if health ~= health_transition_start then
                                    health_transition_old, health_transition_start, health_start = current_health, health, TickFunc()
                                end
                            end

                            local progress = MathClamp((TickFunc() - health_start) / 0.2, 0, 1)

                            current_health = health_transition_old + (health_transition_start - health_transition_old) * progress

                            if progress >= 1 then
                                current_health, health_transition_old, health_transition_start, health_start = health, health, health, 0
                            end

                            do
                                if Script.Visuals.ESP['Healthtext'] and health < max_health then
                                    drawings.HealthText.Text, drawings.HealthText.Visible = ToString(MathFloor(current_health)), true
                                else
                                    drawings.HealthText.Visible = false
                                end

                                drawings.HealthText.TextColor3 = health_color
                            end

                            drawings.Healthbar.Visible = true
                            drawings.BehindHealthbar.Visible = true

                            if Script.Visuals.ESP['Position'] == 'Left' then
                                drawings.HealthbarGradient.Rotation = -90

                                local bg_y = box_y - 2
                                local bg_h = box_h + 5
                                local bg_x = box_x - 5 - bar_thickness

                                drawings.BehindHealthbar.Position = NewUDim2(0, bg_x, 0, bg_y)
                                drawings.BehindHealthbar.Size = NewUDim2(0, bar_thickness, 0, bg_h)

                                local current_bar_height = MathFloor(bg_h * MathClamp(current_health / max_health, 0, 1))

                                drawings.Healthbar.Position = NewUDim2(0, bg_x, 0, bg_y + (bg_h - current_bar_height))
                                drawings.Healthbar.Size = NewUDim2(0, bar_thickness, 0, current_bar_height)
                                health_offset = MathClamp(health_offset, 0, 1)
                                drawings.HealthbarGradient.Offset = NewVector2(0, -health_offset)

                                local target_text_pos = NewUDim2(0, bg_x - 14, 0, bg_y + (bg_h - current_bar_height) - 4)

                                drawings.HealthText.Position = drawings.HealthText.Position:Lerp(target_text_pos, progress)
                            elseif Script.Visuals.ESP['Position'] == 'Bottom' then
                                drawings.HealthbarGradient.Rotation = 0

                                local bg_x = box_x
                                local bg_w = box_w + 1
                                local bg_y = box_y + box_h + 5

                                drawings.BehindHealthbar.Position = NewUDim2(0, bg_x, 0, bg_y)
                                drawings.BehindHealthbar.Size = NewUDim2(0, bg_w, 0, bar_thickness)

                                local current_bar_width = MathFloor(bg_w * MathClamp(current_health / max_health, 0, 1))

                                drawings.Healthbar.Position = NewUDim2(0, bg_x, 0, bg_y)
                                drawings.Healthbar.Size = NewUDim2(0, current_bar_width, 0, bar_thickness)
                                health_offset = MathClamp(health_offset, 0, 1)
                                drawings.HealthbarGradient.Offset = NewVector2(health_offset, 0)

                                local target_text_pos = NewUDim2(0, bg_x + current_bar_width + 4, 0, bg_y - 3)

                                drawings.HealthText.Position = drawings.HealthText.Position:Lerp(target_text_pos, progress)
                            end
                            if Script.Visuals.ESP['Lerp'] then
                                drawings.HealthbarGradient.Color = ColorSequence.new{
                                    ColorSequenceKeypoint.new(0, health_color),
                                    ColorSequenceKeypoint.new(1, health_color),
                                }
                            else
                                drawings.HealthbarGradient.Color = ColorSequence.new{
                                    ColorSequenceKeypoint.new(0, Script.Visuals.ESP['Gradient1']),
                                    ColorSequenceKeypoint.new(0.5, Script.Visuals.ESP['Gradient2']),
                                    ColorSequenceKeypoint.new(1, Script.Visuals.ESP['Gradient3']),
                                }
                            end
                        else
                            drawings.Healthbar.Visible, drawings.HealthText.Visible, drawings.BehindHealthbar.Visible = false, false, false
                        end
                        if (on_screen) and Script.Visuals.ESP['Indicator'] then
                            drawings.Flag1.Visible = true
                            drawings.Flag2.Visible = true

                            if ESP_Stuff.functions:is_visible(char_model) then
                                drawings.Flag1.Visible = true
                                drawings.Flag1.Text = 'Vis'
                            else
                                drawings.Flag1.Visible = false
                                drawings.Flag1.Text = ''
                            end

                            local box_side = box_x + box_w + (is_full_box and 3 or 0)
                            local box_top = box_y - (is_full_box and 3 or 0)

                            if Script.Visuals.ESP['Types'] == 'Corner' then
                                drawings.Flag1.Position = NewUDim2(0, box_side + 4, 0, box_top + 2)
                                drawings.Flag2.Position = NewUDim2(0, box_side + 4, 0, box_top + 2 + drawings.Flag1.TextBounds.Y)
                            elseif Script.Visuals.ESP['Types'] == 'Full' then
                                drawings.Flag1.Position = NewUDim2(0, box_side + 4, 0, box_top)
                                drawings.Flag2.Position = NewUDim2(0, box_side + 4, 0, box_top + drawings.Flag1.TextBounds.Y)
                            end

                            drawings.Flag1.Position = drawings.Flag1.Position + NewUDim2(0, drawings.Flag1.TextBounds.X, 0, 0)
                            drawings.Flag2.Position = drawings.Flag2.Position + NewUDim2(0, drawings.Flag2.TextBounds.X, 0, 0)
                        else
                            drawings.Flag1.Visible = false
                            drawings.Flag2.Visible = false
                        end
                    else
                        hide_esp()
                    end
                else
                    hide_esp()
                end
            else
                hide_esp()
            end
        end)
    end

    coroutine.wrap(update)()
end)

do
    for _, v in pairs(Players:GetPlayers())do
        if v.Name ~= LocalPlayer.Name then
            coroutine.wrap(ESP)(v)
        end
    end

    Script.Function.Connection(Players.PlayerAdded, LPH_NO_VIRTUALIZE(function(v)
        TaskDelay(1, function()
            coroutine.wrap(ESP)(v)
        end)
    end))
end
