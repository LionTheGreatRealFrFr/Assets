do
    function ESP_Stuff.fonts.cache:Register_Font(Name, Weight, Style, Asset)
        if not isfolder('Elisium') then makefolder('Elisium') end
        local asset = 'Elisium/' .. Asset.Id
        local font = 'Elisium/' .. Name .. '.font'
        if not isfile(asset) then writefile(asset, Asset.Font) end
        writefile(font, HttpService:JSONEncode({
            name = Name,
            faces = {{ name = 'Regular', weight = Weight, style = Style, assetId = getcustomasset(asset) }},
        }))
        return getcustomasset(font)
    end
    ESP_Stuff.fonts.options = ({ ProggyTiny = Font.fromEnum(Enum.Font.GothamBold) })
end

do
    function ESP_Stuff.functions:create(class, prop)
        local inst = TypeOf(class) == 'string' and NewInstance(class) or class
        for property, val in pairs(prop) do
            inst[property] = val
        end
        return inst
    end

    ESP_Stuff.functions.is_visible = LPH_NO_VIRTUALIZE(function(self, Destination)
        local part = Destination and Destination.PrimaryPart
        if not part then return false end
        local origin = Camera.CFrame.p
        local RaycastResult = Workspace:Raycast(origin, (part.Position - origin).Unit * 10000, _indicator_params)
        return RaycastResult and RaycastResult.Instance:IsDescendantOf(Destination)
    end)

    local increase = NewVector3(0, 0, 0)
    local vertices = {
        {-0.5, -0.5, -0.5}, {-0.5,  0.5, -0.5},
        { 0.5, -0.5, -0.5}, { 0.5,  0.5, -0.5},
        {-0.5, -0.5,  0.5}, {-0.5,  0.5,  0.5},
        { 0.5, -0.5,  0.5}, { 0.5,  0.5,  0.5},
    }

    ESP_Stuff.functions.custom_bounds = LPH_NO_VIRTUALIZE(function(self, model)
        local min_x, min_y, min_z = MathHuge, MathHuge, MathHuge
        local max_x, max_y, max_z = -MathHuge, -MathHuge, -MathHuge
        local min_width = 2.5

        for _, part in model:GetChildren() do
            if part:IsA('BasePart') then
                local cframe, size = part.CFrame, part.Size
                local sx, sy, sz = size.X, (size.Y + 0.2), size.Z

                for _, v in vertices do
                    local w = cframe:PointToWorldSpace(NewVector3(v[1] * sx, (v[2] + 0.2) * sy, v[3] * sz))
                    local wx, wy, wz = w.X, w.Y, w.Z

                    if wx < min_x then min_x = wx end
                    if wy < min_y then min_y = wy end
                    if wz < min_z then min_z = wz end
                    if wx > max_x then max_x = wx end
                    if wy > max_y then max_y = wy end
                    if wz > max_z then max_z = wz end
                end
            end
        end

        if min_x == MathHuge then return end

        local size_x = MathMax(max_x - min_x, min_width)
        local size_y = max_y - min_y
        local size_z = max_z - min_z
        local cx = (min_x + max_x) / 2
        local cy = (min_y + max_y) / 2
        local cz = (min_z + max_z) / 2
        local center = NewVector3(cx, cy, cz)

        return NewCFrame(center), NewVector3(size_x, size_y, size_z) + increase, center
    end)

    ESP_Stuff.functions.get_tool_name = LPH_NO_VIRTUALIZE(function(self, character)
        for _, v in character:GetChildren() do
            if not v:IsA('Model') then continue end
            if v.Name == 'Hair' or v.Name == 'HolsterModel' then continue end
            if not v.PrimaryPart then continue end
            if v:FindFirstChild('Detail') or v:FindFirstChild('Main') or v:FindFirstChild('Handle')
            or v:FindFirstChild('Attachments') or v:FindFirstChild('ArrowAttach') or v:FindFirstChild('Attach') then
                return v.Name
            end
        end
        return 'none'
    end)
end

