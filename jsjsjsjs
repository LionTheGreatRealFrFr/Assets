        BottomSideFix     = ESP_Stuff.functions:create('Frame', { Parent = esp_holder, Size = NewUDim2(0,1,0,6), ZIndex = 999 }),
        BottomRightSideFix= ESP_Stuff.functions:create('Frame', { Parent = esp_holder, Size = NewUDim2(0,1,0,6), ZIndex = 999 }),
        LeftTop           = ESP_Stuff.functions:create('Frame', { Parent = esp_holder, ZIndex = 3 }),
        LeftSide          = ESP_Stuff.functions:create('Frame', { Parent = esp_holder }),
        RightTop          = ESP_Stuff.functions:create('Frame', { Parent = esp_holder, ZIndex = 3 }),
        RightSide         = ESP_Stuff.functions:create('Frame', { Parent = esp_holder }),
        BottomSide        = ESP_Stuff.functions:create('Frame', { Parent = esp_holder }),
        BottomDown        = ESP_Stuff.functions:create('Frame', { Parent = esp_holder }),
        BottomRightSide   = ESP_Stuff.functions:create('Frame', { Parent = esp_holder }),
        BottomRightDown   = ESP_Stuff.functions:create('Frame', { Parent = esp_holder }),
        Arrow = ESP_Stuff.functions:create('ImageLabel', {
            Parent = arrows_holder, BackgroundTransparency = 1, AnchorPoint = NewVector2(0.5, 0.5),
        }),
    }

    drawings.HealthbarGradient.Parent = drawings.Healthbar
    drawings.BoxFillGradient.Parent = drawings.BoxFill
    drawings.Outline.Parent = drawings.Box
    drawings.Outline2.Parent = drawings.Box2

    local update = LPH_NO_VIRTUALIZE(function()
        local health_start = 0
        local health_transition_start = 0
        local health_transition_old = 0
        local current_health = 0

        -- cached tool name, updated via events instead of polling
        local _cached_tool = 'none'

        -- cached bounds, only recalculate when root moves
        local _lastRootCF = nil
        local _cachedCF, _cachedSize, _cachedPos = nil, nil, nil

        -- cached gradient colorsequences
        local _lastGradC1, _lastGradC2, _lastGradC3 = nil, nil, nil
        local _cachedBoxGradCS = nil
        local _lastHealthColor = nil
        local _cachedHealthCS = nil
        local _lastGrad1, _lastGrad2, _lastGrad3 = nil, nil, nil
        local _cachedBarCS = nil

        local function hide_esp()
            for i = 1, #_ESP_HIDE_KEYS do
                drawings[_ESP_HIDE_KEYS[i]].Visible = false
            end
        end

        local function clear_esp()
            for _, v in next, drawings do v:Destroy() end
            if esp_connection then esp_connection:Disconnect() end
            esp_holder:Destroy()
            arrows_holder:Destroy()
        end

        Script.Function.Connection(model.Destroying, clear_esp)

        -- tool caching via events
        local function setup_tool_cache(char)
            char.ChildAdded:Connect(function(child)
                if child:IsA('Tool') then _cached_tool = child.Name end
            end)
            char.ChildRemoved:Connect(function(child)
                if child:IsA('Tool') then _cached_tool = 'none' end
            end)
            -- init from existing tool
            for _, c in char:GetChildren() do
                if c:IsA('Tool') then _cached_tool = c.Name break end
            end
        end

        if model.Character then setup_tool_cache(model.Character) end
        model.CharacterAdded:Connect(function(char)
            _cached_tool = 'none'
            _lastRootCF = nil
            setup_tool_cache(char)
        end)

        local _cachedHumanoid = nil

        esp_connection = Script.Function.Connection(RunService['PreRender'], LPH_NO_VIRTUALIZE(function()
            local char_model = model and model.Character
            if not char_model then hide_esp() return end

            _cachedHumanoid = char_model:FindFirstChildOfClass('Humanoid') or _cachedHumanoid
            if not _cachedHumanoid then hide_esp() return end

            local humanoid = _cachedHumanoid
            if humanoid.Health <= 0 then hide_esp() return end

            local root = char_model:FindFirstChild('HumanoidRootPart')
            if not root then hide_esp() return end

            -- only recalculate bounds when root actually moves
            local rootCF = root.CFrame
            if rootCF ~= _lastRootCF then
                _lastRootCF = rootCF
                _cachedCF, _cachedSize, _cachedPos = ESP_Stuff.functions:custom_bounds(char_model)
            end

            local position = _cachedPos
            local size = _cachedSize

            if not position then hide_esp() return end

            local max_distance
            local measurement = Script.Visuals.ESP['Measurement']
            local camPos = Camera.CFrame.Position
            local rawDist = (camPos - position).Magnitude

            if measurement == 'Studs' then
                max_distance = rawDist
            elseif measurement == 'Meters' then
                max_distance = rawDist / 3.5714285714
            end

            local esp = Script.Visuals.ESP
            local distCheck = esp['Distance_Check']
            local teamCheck = esp['Teamcheck']

            if not (esp['Enabled'] and max_distance
                and TypeOf(max_distance) == 'number'
                and TypeOf(distCheck) == 'number'
                and max_distance <= distCheck
                and (not teamCheck or (model ~= LocalPlayer and ((LocalPlayer.Team ~= model.Team and model.Team) or (not LocalPlayer.Team and not model.Team))))
            ) then
                hide_esp() return
            end

            local pos, on_screen = Camera:WorldToScreenPoint(position)
            local pz = pos.Z
            local height = math.tan(MathRad(Camera.FieldOfView / 2)) * 2 * pz
            local vsy = viewport_size.Y
            local scale_x = MathFloor((vsy / height) * size.X)
            local scale_y = MathFloor((vsy / height) * size.Y)
            local pos_x = MathFloor(pos.X)
            local pos_y = MathFloor(pos.Y)
            local box_w = scale_x - 1
            local box_h = scale_y - 2
            local box_x = pos_x - MathFloor(scale_x / 2)
            local box_y = pos_y - MathFloor(scale_y / 2)
            local is_full_box = esp['Types'] == 'Full'
            local highlight_active = esp['Highlight'] and highlight_player == model and esp['Highlight_Accent']
            local accent_color = highlight_active and esp['Highlight_Accent'] or esp['Box_Accent']

            -- full box
            if on_screen and esp['Boxes'] and is_full_box then
                drawings.Box.Size        = NewUDim2(0, box_w,     0, box_h + 1)
                drawings.Box2.Size       = NewUDim2(0, box_w + 2, 0, box_h + 3.5)
                drawings.BoxFill.Size    = NewUDim2(0, box_w,     0, box_h + 1)
                drawings.Box.Position    = NewUDim2(0, box_x,     0, box_y)
                drawings.Box2.Position   = NewUDim2(0, box_x - 1, 0, box_y - 1)
                drawings.BoxFill.Position= NewUDim2(0, box_x,     0, box_y)
                drawings.Box.Visible     = true
                drawings.Box2.Visible    = true
                drawings.BoxFill.Visible = esp.BoxFill
                drawings.BoxFill.BackgroundTransparency = esp.BoxFill_Transparency

                if esp.BoxFill_Gradient then
                    local gc = esp.BoxFill_GradientColors
                    local c1, c2, c3 = gc[1], gc[2], gc[3]
                    if c1 ~= _lastGradC1 or c2 ~= _lastGradC2 or c3 ~= _lastGradC3 then
                        _lastGradC1, _lastGradC2, _lastGradC3 = c1, c2, c3
                        _cachedBoxGradCS = ColorSequence.new{
                            ColorSequenceKeypoint.new(0,   c1),
                            ColorSequenceKeypoint.new(0.5, c2),
                            ColorSequenceKeypoint.new(1,   c3),
                        }
                    end
                    drawings.BoxFillGradient.Enabled = true
                    drawings.BoxFillGradient.Color = _cachedBoxGradCS
                    drawings.BoxFill.BackgroundColor3 = C3_WHITE
                else
                    drawings.BoxFillGradient.Enabled = false
                    drawings.BoxFill.BackgroundColor3 = drawings.BoxFill.BackgroundColor3:Lerp(esp.BoxFill_Color, 0.04)
                end

                drawings.Outline2.Color = drawings.Outline2.Color:Lerp(accent_color, 0.04)
            else
                drawings.Box.Visible    = false
                drawings.Box2.Visible   = false
                drawings.BoxFill.Visible= false
            end

            -- corner box
            if on_screen and esp['Boxes'] and esp['Types'] == 'Corner' then
                local sx3 = MathFloor(scale_x / 3)
                local sy4 = MathFloor(scale_y / 4)

                -- update the reusable table in place
                _corner_positions[1][2]  = box_x;           _corner_positions[1][3]  = box_y
                _corner_positions[2][2]  = box_x + box_w;   _corner_positions[2][3]  = box_y
                _corner_positions[3][2]  = box_x;           _corner_positions[3][3]  = box_y + box_h - 6
                _corner_positions[4][2]  = box_x + box_w;   _corner_positions[4][3]  = box_y + box_h - 6
                _corner_positions[5][2]  = box_x;           _corner_positions[5][3]  = box_y;  _corner_positions[5][4] = sx3; _corner_positions[5][5] = 1
                _corner_positions[6][2]  = box_x;           _corner_positions[6][3]  = box_y;  _corner_positions[6][4] = 1;   _corner_positions[6][5] = sy4
                _corner_positions[7][2]  = box_x+box_w+1;   _corner_positions[7][3]  = box_y;  _corner_positions[7][4] = sx3; _corner_positions[7][5] = 1
                _corner_positions[8][2]  = box_x + box_w;   _corner_positions[8][3]  = box_y;  _corner_positions[8][4] = 1;   _corner_positions[8][5] = sy4
                _corner_positions[9][2]  = box_x;           _corner_positions[9][3]  = box_y+box_h+1; _corner_positions[9][4] = 1;   _corner_positions[9][5] = sy4
                _corner_positions[10][2] = box_x;           _corner_positions[10][3] = box_y+box_h+1; _corner_positions[10][4] = sx3; _corner_positions[10][5] = 1
                _corner_positions[11][2] = box_x+box_w+1;   _corner_positions[11][3] = box_y+box_h+1; _corner_positions[11][4] = 1;   _corner_positions[11][5] = sy4
                _corner_positions[12][2] = box_x+box_w+1;   _corner_positions[12][3] = box_y+box_h+1; _corner_positions[12][4] = sx3; _corner_positions[12][5] = 1

                for _, v in _corner_positions do
                    local name, x_p, y_p, width, t_height, anchor = v[1], v[2], v[3], v[4], v[5], v[6]
                    local drawing = drawings[name]
                    drawing.Position = NewUDim2(0, x_p, 0, y_p)
                    if not name:find('Fix', 1, true) then
                        drawing.Size = NewUDim2(0, width, 0, t_height)
                        drawing.AnchorPoint = anchor
                        drawing.BorderSizePixel = 1
                    else
                        drawing.BorderSizePixel = 0
                    end
                    drawing.Visible = true
                    drawing.BackgroundColor3 = drawing.BackgroundColor3:Lerp(accent_color, 0.04)
                end
            else
                for i = 1, #_CORNER_HIDE do
                    drawings[_CORNER_HIDE[i]].Visible = false
                end
            end

            -- arrow
            if not on_screen and esp['Arrows'] then
                drawings.Arrow.Visible = true
                drawings.Arrow.Size = NewUDim2(0, esp['Size'], 0, esp['Size'])

                if esp['Rainbow'] then
                    drawings.Arrow.ImageColor3 = HSV((TickFunc() * 0.5) % 1, 1, 1)
                else
                    drawings.Arrow.ImageColor3 = esp['Arrows_Accent']
                end

                local center = viewport_size / 2
                local proj = Camera.CFrame:PointToObjectSpace(root.Position)
                local angle = math.atan2(proj.Z, proj.X)
                local radius = esp['Radius']

                drawings.Arrow.Image = esp['Points'] == 'Three'
                    and 'http://www.roblox.com/asset/?id=282305485'
                    or  'http://www.roblox.com/asset/?id=15000587389'
                drawings.Arrow.Position = NewUDim2(0, center.X + math.cos(angle) * radius - (esp['Size'] / 2), 0, center.Y + math.sin(angle) * radius - (esp['Size'] / 2))
                drawings.Arrow.Rotation = math.deg(angle) + 90
                drawings.Arrow.ImageTransparency = math.sin(TickFunc() * 4.5) * 0.5 + 0.5
            else
                drawings.Arrow.Visible = false
            end

            -- name
            if on_screen and esp['Names'] then
                drawings.name.Visible = true
                drawings.name.TextColor3 = drawings.name.TextColor3:Lerp(
                    highlight_active and esp['Highlight_Accent'] or esp['Accent'], 0.04)
                drawings.name.Position = NewUDim2(0, pos_x - 2, 0, box_y - (is_full_box and 15 or 12))
            else
                drawings.name.Visible = false
            end

            -- distance
            if on_screen and esp['Distance'] then
                drawings.distance.TextColor3 = drawings.distance.TextColor3:Lerp(
                    highlight_active and esp['Highlight_Accent'] or esp['Distance_Accent'], 0.04)
                drawings.distance.Text = measurement == 'Studs'
                    and string.format('%ds', MathFloor(max_distance))
                    or  string.format('%dm', MathFloor(max_distance))
                drawings.distance.Visible = true
            else
                drawings.distance.Visible = false
            end

            -- weapon (uses cached tool name)
            if on_screen and esp['Weapon'] then
                drawings.weapon.Visible = true
                drawings.weapon.TextColor3 = drawings.weapon.TextColor3:Lerp(
                    highlight_active and esp['Highlight_Accent'] or esp['Weapon_Accent'], 0.04)
                drawings.weapon.Text = _cached_tool
            else
                drawings.weapon.Visible = false
            end

            -- text layout
            local bar_thickness  = esp['Width'] or 2
            local bottom_spacing = (esp['Healthbar'] and esp['Position'] == 'Bottom') and (8 + bar_thickness) or 5
            local text_base_y    = box_y + box_h + (is_full_box and 3 or 0) + bottom_spacing

            if esp['Distance'] and esp['Weapon'] then
                drawings.weapon.Position   = NewUDim2(0, pos_x, 0, text_base_y)
                drawings.distance.Position = NewUDim2(0, pos_x, 0, text_base_y + 11)
            elseif esp['Distance'] then
                drawings.distance.Position = NewUDim2(0, pos_x, 0, text_base_y + 1)
            elseif esp['Weapon'] then
                drawings.weapon.Position   = NewUDim2(0, pos_x, 0, text_base_y)
            end

            -- healthbar
            if on_screen and esp['Healthbar'] then
                local health     = MathFloor(humanoid.Health)
                local max_health = humanoid.MaxHealth
                local t          = MathClamp(health / max_health, 0, 1)
                local health_color = NewColor3(1,0,0):lerp(NewColor3(0.7,0.8,0), t)
                health_color = health_color:lerp(NewColor3(0,1,0), MathClamp((t - 0.5) * 2, 0, 1))

                do
                    if health ~= health_transition_start then
                        health_transition_old  = current_health
                        health_transition_start = health
                        health_start = TickFunc()
                    end
                end

                local progress = MathClamp((TickFunc() - health_start) / 0.2, 0, 1)
                current_health = health_transition_old + (health_transition_start - health_transition_old) * progress

                if progress >= 1 then
                    current_health, health_transition_old, health_transition_start, health_start = health, health, health, 0
                end

                if esp['Healthtext'] and health < max_health then
                    drawings.HealthText.Text    = ToString(MathFloor(current_health))
                    drawings.HealthText.Visible = true
                else
                    drawings.HealthText.Visible = false
                end
                drawings.HealthText.TextColor3 = health_color

                drawings.Healthbar.Visible      = true
                drawings.BehindHealthbar.Visible= true

                local position_type = esp['Position']

                if position_type == 'Left' then
                    drawings.HealthbarGradient.Rotation = -90
                    local bg_x = box_x - 5 - bar_thickness
                    local bg_y = box_y - 2
                    local bg_h = box_h + 5
                    local current_bar_height = MathFloor(bg_h * MathClamp(current_health / max_health, 0, 1))

                    drawings.BehindHealthbar.Position = NewUDim2(0, bg_x, 0, bg_y)
                    drawings.BehindHealthbar.Size     = NewUDim2(0, bar_thickness, 0, bg_h)
                    drawings.Healthbar.Position       = NewUDim2(0, bg_x, 0, bg_y + (bg_h - current_bar_height))
                    drawings.Healthbar.Size           = NewUDim2(0, bar_thickness, 0, current_bar_height)
                    drawings.HealthbarGradient.Offset = NewVector2(0, -MathClamp(MathFloor((max_health - health) / 10) * 0.1, 0, 1))
                    drawings.HealthText.Position      = drawings.HealthText.Position:Lerp(
                        NewUDim2(0, bg_x - 14, 0, bg_y + (bg_h - current_bar_height) - 4), progress)

                elseif position_type == 'Bottom' then
                    drawings.HealthbarGradient.Rotation = 0
                    local bg_x = box_x
                    local bg_w = box_w + 1
                    local bg_y = box_y + box_h + 5
                    local current_bar_width = MathFloor(bg_w * MathClamp(current_health / max_health, 0, 1))

                    drawings.BehindHealthbar.Position = NewUDim2(0, bg_x, 0, bg_y)
                    drawings.BehindHealthbar.Size     = NewUDim2(0, bg_w, 0, bar_thickness)
                    drawings.Healthbar.Position       = NewUDim2(0, bg_x, 0, bg_y)
                    drawings.Healthbar.Size           = NewUDim2(0, current_bar_width, 0, bar_thickness)
                    drawings.HealthbarGradient.Offset = NewVector2(MathClamp(MathFloor((max_health - health) / 10) * 0.1, 0, 1), 0)
                    drawings.HealthText.Position      = drawings.HealthText.Position:Lerp(
                        NewUDim2(0, bg_x + current_bar_width + 4, 0, bg_y - 3), progress)
                end

                -- cached healthbar colorsequence
                if esp['Lerp'] then
                    if health_color ~= _lastHealthColor then
                        _lastHealthColor = health_color
                        _cachedHealthCS = ColorSequence.new{
                            ColorSequenceKeypoint.new(0, health_color),
                            ColorSequenceKeypoint.new(1, health_color),
                        }
                    end
                    drawings.HealthbarGradient.Color = _cachedHealthCS
                else
                    local g1, g2, g3 = esp['Gradient1'], esp['Gradient2'], esp['Gradient3']
                    if g1 ~= _lastGrad1 or g2 ~= _lastGrad2 or g3 ~= _lastGrad3 then
                        _lastGrad1, _lastGrad2, _lastGrad3 = g1, g2, g3
                        _cachedBarCS = ColorSequence.new{
                            ColorSequenceKeypoint.new(0,   g1),
                            ColorSequenceKeypoint.new(0.5, g2),
                            ColorSequenceKeypoint.new(1,   g3),
                        }
                    end
                    drawings.HealthbarGradient.Color = _cachedBarCS
                end
            else
                drawings.Healthbar.Visible, drawings.HealthText.Visible, drawings.BehindHealthbar.Visible = false, false, false
            end

            -- indicator
            if on_screen and esp['Indicator'] then
                if ESP_Stuff.functions:is_visible(char_model) then
                    drawings.Flag1.Visible = true
                    drawings.Flag1.Text    = 'Vis'
                else
                    drawings.Flag1.Visible = false
                    drawings.Flag1.Text    = ''
                end

                drawings.Flag2.Visible = true

                local box_side = box_x + box_w + (is_full_box and 3 or 0)
                local box_top  = box_y - (is_full_box and 3 or 0)
                local f1y      = drawings.Flag1.TextBounds.Y

                if esp['Types'] == 'Corner' then
                    drawings.Flag1.Position = NewUDim2(0, box_side + 4 + drawings.Flag1.TextBounds.X, 0, box_top + 2)
                    drawings.Flag2.Position = NewUDim2(0, box_side + 4 + drawings.Flag2.TextBounds.X, 0, box_top + 2 + f1y)
                else
                    drawings.Flag1.Position = NewUDim2(0, box_side + 4 + drawings.Flag1.TextBounds.X, 0, box_top)
                    drawings.Flag2.Position = NewUDim2(0, box_side + 4 + drawings.Flag2.TextBounds.X, 0, box_top + f1y)
                end
            else
                drawings.Flag1.Visible = false
                drawings.Flag2.Visible = false
            end
        end))
    end)

    task.spawn(update)
end)

do
    for _, v in Players:GetPlayers() do
        if v.Name ~= LocalPlayer.Name then
            task.spawn(ESP, v)
        end
    end

    Script.Function.Connection(Players.PlayerAdded, LPH_NO_VIRTUALIZE(function(v)
        task.delay(1, ESP, v)
    end))
end
